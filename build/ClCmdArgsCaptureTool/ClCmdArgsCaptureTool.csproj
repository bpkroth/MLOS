<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <ProjectGuid>{93112024-F822-4624-8A55-B22F2121A0FE}</ProjectGuid>
    <OutputType>Exe</OutputType>
    <RootNamespace>CodeBook</RootNamespace>
    <AssemblyName>$(MSBuildProjectName)</AssemblyName>
  </PropertyGroup>

  <!-- Set some other standard .NET.Sdk properties for all projects. -->
  <PropertyGroup Label="CommonComponentProjectNetCoreSettings">
    <!-- Declare the target framework for all SettingsRegistry projects. -->
    <TargetFramework>netcoreapp3.1</TargetFramework>

    <!-- Disable .NET.Sdk behavior of including all *.cs files within the project's directory by default. -->
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>

    <!-- Include some of the package version properties from below in the dlls as well. -->
    <GenerateAssemblyFileVersionAttribute>true</GenerateAssemblyFileVersionAttribute>
    <GenerateAssemblyVersionAttribute>true</GenerateAssemblyVersionAttribute>
    <GenerateAssemblyInformationalVersionAttribute>true</GenerateAssemblyInformationalVersionAttribute>
    <GenerateAssemblyCopyrightAttribute>true</GenerateAssemblyCopyrightAttribute>

    <!-- Configure warning levels and errors. -->
    <WarningLevel>4</WarningLevel>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <WarningsAsErrors>true</WarningsAsErrors>
    <CodeAnalysisTreatWarningsAsErrors>true</CodeAnalysisTreatWarningsAsErrors>
    <StyleCopTreatErrorsAsWarnings>false</StyleCopTreatErrorsAsWarnings>
    <CodeAnalysisRuleSet>$(MSBuildThisFileDirectory)/$(MSBuildProjectName).StyleCop.ruleset</CodeAnalysisRuleSet>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <!-- Configure stylecop analyzers. -->
  <ItemGroup Label="EnableStyleCopForExample">
    <PackageReference Include="Microsoft.CodeAnalysis.FxCopAnalyzers" Version="2.9.4">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
    <PackageReference Include="StyleCop.Analyzers" Version="1.1.118">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
    <!-- Provide your own stylecop.json config (for this example we reuse the core MLOS one) -->
    <AdditionalFiles Include="$(MSBuildThisFileDirectory)/stylecop.json" Visible="false">
      <Link>stylecop.json</Link>
    </AdditionalFiles>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Data.SQLite" Version="5.0.1" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="$(MSBuildProjectName).cs" />
  </ItemGroup>

  <PropertyGroup Label="Nuget Package Properties">
    <Version>0.1.0-alpha</Version>
    <!-- TODO: Replace with the actual repo. -->
    <PackageProjectUrl>https://github.com/Microsoft/MLOS</PackageProjectUrl>
    <RepositoryUrl>https://github.com/Microsoft/MLOS.git</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <Authors>Microsoft</Authors>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <Copyright>Copyright (c) Microsoft Corporation.  All rights reserved.</Copyright>
    <PackageId>$(MSBuildProjectName)</PackageId>
    <PackageDescription>Compile command arguments capture tool</PackageDescription>
    <PackageTags>CodeBook;native;nativepackage</PackageTags>

    <!-- By default, also create the nuget package whenever we build. -->
    <GeneratePackageOnBuild Condition="'$(GeneratePackageOnBuild)' == ''">true</GeneratePackageOnBuild>

    <!-- Unless specified on the commandline, set the default package output to the target/ dir. -->
    <PackageOutputPath>$(MSBuildThisFileDirectory)\pkg\</PackageOutputPath>

    <!-- Also create a .snupkg along side the package for eventual publishing of symbols to nuget.org -->
    <IncludeSymbols>true</IncludeSymbols>
    <!--
      When this property is omitted a separate .symbols.nupkg file is created
      that includes both the .dll and .pdb.
    -->
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>

    <!-- Include the .pdb symbols file in the standard package to make debugging easier. -->
    <AllowedOutputExtensionsInPackageBuildOutputFolder Condition="'$(Configuration)' == 'Debug'">$(AllowedOutputExtensionsInPackageBuildOutputFolder);.pdb</AllowedOutputExtensionsInPackageBuildOutputFolder>
  </PropertyGroup>

  <PropertyGroup Label="PackageProps">
    <!-- Projects using a PackageReference to this tool should not attempt to link against it. -->
    <DevelopmentDependency>true</DevelopmentDependency>
    <!-- Place the outputs in the tools/ directory instead of the lib/ directory. -->
    <!-- Note: We can't use PackAsTool since it won't allow us to PackageReference it or automatically pull in our build/ rules. -->
    <IsTool>true</IsTool>
    <!-- Since we did that, there are no items in the lib/ directory, so we need to ignore that warning. -->
    <NoWarn>$(NoWarn);NU5128</NoWarn>
    <!-- Don't mention which dotnet framework in the dependencies. -->
    <SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
  </PropertyGroup>
  <ItemGroup>
    <None Include="$(OutDir)\$(TargetName).exe">
      <Pack>true</Pack>
      <PackagePath>tools/</PackagePath>
    </None>
    <None Include="$(OutDir)\**\*.dll" Exclude="$(OutDir)\$(TargetName).dll">
      <Pack>true</Pack>
      <PackagePath>tools/</PackagePath>
    </None>
    <None Include="$(OutDir)\**\*.json" Exclude="$(OutDir)\$(TargetName).runtimeconfig.json">
      <Pack>true</Pack>
      <PackagePath>tools/</PackagePath>
    </None>
  </ItemGroup>
</Project>
